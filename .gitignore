# =========================
# 智慧教学平台 · 根目录 .gitignore
# =========================

# ----- OS -----
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ----- IDE / Editor -----
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.iml
*.iws
*.ipr
.project
.classpath
.settings/
.factorypath
.apt_generated
.springBeans
.sts4-cache

# ----- Env & Secrets -----
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
credentials.json
secrets/

# 本地覆盖配置（含数据库密码、API Key、JWT）
**/application-local.yml
**/application-local.yaml

# ----- Logs & Temp -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.tmp
*.temp
*.bak
*.swp
*~

# ----- Backend (Spring Boot / Maven) -----
OnlineLearningPlatform/target/
OnlineLearningPlatform/.mvn/wrapper/maven-wrapper.jar
**/target/
!**/src/main/**/target/
!**/src/test/**/target/
**/build/
!**/src/main/**/build/
!**/src/test/**/build/
HELP.md

# ----- Frontend (Vue / Vite / Node) -----
**/node_modules/
**/dist/
**/dist-ssr/
**/coverage/
*.local
*.tsbuildinfo
.eslintcache
**/cypress/videos/
**/cypress/screenshots/
**/__screenshots__/
*.timestamp-*-*.mjs

# ----- Cursor / AI tooling -----
.cursor/
!.cursor/rules/
!.cursor/skills/

# ----- Misc -----
*.class
*.jar
*.war
*.ear
hs_err_pid*
replay_pid*
