# 复制本文件为 application-local.yml 并填写本地配置（application-local.yml 已加入 .gitignore）
spring:
  datasource:
    url: jdbc:mysql://localhost:3306/online_learning_platform?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=utf-8
    username: root
    password: your_db_password
  ai:
    dashscope:
      api-key: your_dashscope_api_key

# 可选：本地开启 SQL 日志
# mybatis-plus:
#   configuration:
#     log-impl: org.apache.ibatis.logging.stdout.StdOutImpl

app:
  jwt:
    secret-key: change-me-to-a-long-random-secret-at-least-32-chars
    ttl-millis: 7200000
